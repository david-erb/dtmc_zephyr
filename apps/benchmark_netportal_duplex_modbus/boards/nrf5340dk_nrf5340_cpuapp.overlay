/* a second UART (uart1) on Tx=P1.01 Rx=P1.00 */
&uart1 {
    label = "benchmark_uart";
    status = "okay";

    benchmark_modbus: modbus {
        compatible = "zephyr,modbus-serial";
        status = "okay";
        label = "benchmark_modbus"; /* <-- THIS is what modbus_iface_get_by_name() will match */
    };
};
